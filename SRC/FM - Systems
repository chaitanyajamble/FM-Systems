Business logic for the 'Hybrid Workplace Planning Calculator', incl. AI narrative.
"""
Business logic for the 'Hybrid Workplace Planning Calculator' section.
 
Numeric estimates are computed deterministically; the LLM is only used
afterward to translate the numbers into a short, human-readable narrative
(mirroring the 'AI Narratives' and 'Predictive Modeling' capabilities the
page lists under the Executives persona).
"""
import math
 
from app.llm.client import OpenAIClient
from app.models.schemas import CalculatorInput, CalculatorResult
 
_NARRATIVE_SYSTEM_PROMPT = (
    "You are a real estate portfolio analyst. Given workplace utilization "
    "metrics, write a concise, 3-4 sentence executive narrative explaining "
    "what the numbers mean and one concrete recommendation. Avoid jargon and "
    "do not repeat the raw numbers verbatim; interpret them."
)
 
 
def estimate(payload: CalculatorInput) -> CalculatorResult:
    """Compute recommended desk counts, square footage, and savings."""
    peak_daily_attendance = payload.current_employee_count * (
        payload.avg_days_in_office_per_week / 5
    )
    recommended_desk_count = max(1, math.ceil(peak_daily_attendance / payload.desk_sharing_ratio))
 
    current_square_footage = payload.current_desk_count * payload.square_feet_per_desk
    recommended_square_footage = recommended_desk_count * payload.square_feet_per_desk
    square_footage_reduction = max(0.0, current_square_footage - recommended_square_footage)
 
    estimated_annual_savings = square_footage_reduction * payload.annual_cost_per_square_foot
 
    return CalculatorResult(
        recommended_desk_count=recommended_desk_count,
        current_square_footage=round(current_square_footage, 2),
        recommended_square_footage=round(recommended_square_footage, 2),
        square_footage_reduction=round(square_footage_reduction, 2),
        estimated_annual_savings=round(estimated_annual_savings, 2),
    )
 
 
def estimate_with_narrative(payload: CalculatorInput, llm: OpenAIClient) -> CalculatorResult:
    """Run the numeric estimate, then attach an LLM-generated narrative."""
    result = estimate(payload)
 
    user_prompt = (
        f"Employees: {payload.current_employee_count}\n"
        f"Average in-office days/week: {payload.avg_days_in_office_per_week}\n"
        f"Current desks: {payload.current_desk_count}\n"
        f"Recommended desks: {result.recommended_desk_count}\n"
        f"Current square footage: {result.current_square_footage}\n"
        f"Recommended square footage: {result.recommended_square_footage}\n"
        f"Square footage reduction: {result.square_footage_reduction}\n"
        f"Estimated annual savings (USD): {result.estimated_annual_savings}"
    )
    result.ai_narrative = llm.complete(
        _NARRATIVE_SYSTEM_PROMPT, user_prompt, temperature=0.4, max_tokens=200
    )
    return result
 
