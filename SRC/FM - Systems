FastAPI application entrypoint — registers all routers.

import logging
 
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
 
from app.routers import calculator, leads, recommender, resources, solutions
 
logging.basicConfig(level=logging.INFO)
 
app = FastAPI(
    title="FM:Systems Solutions API",
    description="Backend services modeling the FM:Systems Solutions page, with OpenAI-powered insights.",
    version="1.0.0",
)
 
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],  # tighten to specific origins in production
    allow_methods=["*"],
    allow_headers=["*"],
)
 
