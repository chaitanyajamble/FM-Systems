"""
Pydantic models shared across the API.
 
Grouped by the page section they represent, in the same order they
appear on https://fmsystems.com/solutions/
"""
from __future__ import annotations
 
from enum import Enum
from typing import Optional
 
from pydantic import BaseModel, EmailStr, Field
 
 
# ---------------------------------------------------------------------------
# Section: "Solutions to benefit every role"
# ---------------------------------------------------------------------------
class PersonaKey(str, Enum):
    employees = "employees"
    facilities = "facilities"
    executives = "executives"
 
 
class SolutionPersona(BaseModel):
    key: PersonaKey
    audience: str
    headline: str
    description: str
    capabilities: list[str]
    learn_more_url: str
 
 
# ---------------------------------------------------------------------------
# Section: "Featured Resources"
# ---------------------------------------------------------------------------
class ResourceType(str, Enum):
    webinar = "Webinar"
    ebook = "E-Book"
    blog = "Blog"
 
 
class Resource(BaseModel):
    title: str
    resource_type: ResourceType
    description: str
    url: str
 
 
class ResourceSummaryResponse(BaseModel):
    title: str
    ai_teaser: str = Field(..., description="LLM-generated one-line teaser for the resource")
 
 
# ---------------------------------------------------------------------------
# Section: "Hybrid Workplace Planning Calculator"
# ---------------------------------------------------------------------------
class CalculatorInput(BaseModel):
    current_employee_count: int = Field(..., gt=0)
    avg_days_in_office_per_week: float = Field(..., ge=0, le=5)
    current_desk_count: int = Field(..., ge=0)
    square_feet_per_desk: float = Field(120.0, gt=0)
    annual_cost_per_square_foot: float = Field(35.0, gt=0)
    desk_sharing_ratio: float = Field(
        1.5, gt=0, description="Employees per desk under a hybrid/hot-desking model"
    )
 
 
class CalculatorResult(BaseModel):
    recommended_desk_count: int
    current_square_footage: float
    recommended_square_footage: float
    square_footage_reduction: float
    estimated_annual_savings: float
    ai_narrative: Optional[str] = Field(
        None, description="LLM-generated plain-English explanation of the results"
    )
 
 
# ---------------------------------------------------------------------------
# "Get started today" / footer contact form
# ---------------------------------------------------------------------------
class LeadRequest(BaseModel):
    full_name: str
    email: EmailStr
    company: str
    job_title: Optional[str] = None
    persona: Optional[PersonaKey] = None
    message: Optional[str] = Field(None, description="Free-text note from the prospect")
 
 
class LeadResponse(BaseModel):
    lead_id: str
    status: str
    ai_followup_email: Optional[str] = Field(
        None, description="LLM-drafted personalized follow-up email for sales to review"
    )
 
 
# ---------------------------------------------------------------------------
# Cross-section: solution recommender ("Solutions to benefit every role")
# ---------------------------------------------------------------------------
class RecommendationRequest(BaseModel):
    role_description: str = Field(
        ..., min_length=10, description="Free text describing the user's role and challenges"
    )
 
 
class RecommendationResponse(BaseModel):
    recommended_persona: PersonaKey
    rationale: str
    suggested_capabilities: list[str]
 
