from app.data.seed_data import FEATURED_RESOURCES
from app.llm.client import OpenAIClient
from app.models.schemas import Resource, ResourceSummaryResponse
 
_TEASER_SYSTEM_PROMPT = (
    "You are a marketing copywriter for a facilities and workplace management "
    "software company. Write a single punchy sentence (max 20 words) that "
    "teases the value of a resource, to entice a facilities or real estate "
    "professional to click on it. Do not use quotation marks."
)
 
 
def list_resources() -> list[Resource]:
    """Return the featured resources shown on the page."""
    return FEATURED_RESOURCES
 
 
