"""
Business logic for the 'Get started today' / 'Schedule a Demo' contact form.
 
Leads are stored in memory here for demonstration purposes; in production
this would write to a CRM (e.g. Salesforce, HubSpot) instead.
"""
import uuid
from typing import Optional
 
from app.data.seed_data import SOLUTION_PERSONAS
from app.llm.client import OpenAIClient
from app.models.schemas import LeadRequest, LeadResponse, PersonaKey
 
_FOLLOWUP_SYSTEM_PROMPT = (
    "You are a friendly, professional sales development representative for "
    "FM:Systems, a workplace and facilities management software company. "
    "Draft a short follow-up email (under 120 words) to a new inbound lead, "
    "referencing their stated interest and role where relevant. Sign off as "
    "'The FM:Systems Team'. Do not invent specific pricing or dates."
)
 
# In-memory store; swap for a real database/CRM integration in production.
_LEADS: dict[str, LeadRequest] = {}
 
 
def _persona_context(persona: Optional[PersonaKey]) -> str:
    if persona is None:
        return "No specific persona was selected."
    info = SOLUTION_PERSONAS[persona]
    return f"They are interested in the '{info.audience}' solution: {info.headline}."
 
 
def create_lead(payload: LeadRequest, llm: OpenAIClient) -> LeadResponse:
    """Persist a new lead and draft a personalized follow-up email via LLM."""
    lead_id = str(uuid.uuid4())
    _LEADS[lead_id] = payload
 
    user_prompt = (
        f"Name: {payload.full_name}\n"
        f"Company: {payload.company}\n"
        f"Job title: {payload.job_title or 'Unknown'}\n"
        f"{_persona_context(payload.persona)}\n"
        f"Message from lead: {payload.message or 'No additional message provided.'}"
    )
    followup_email = llm.complete(
        _FOLLOWUP_SYSTEM_PROMPT, user_prompt, temperature=0.5, max_tokens=250
    )
 
    return LeadResponse(lead_id=lead_id, status="received", ai_followup_email=followup_email)
 
 
def get_lead(lead_id: str) -> Optional[LeadRequest]:
    """Retrieve a stored lead by id."""
    return _LEADS.get(lead_id)
 
app/services/recommender_service.py
LLM-powered persona recommender with a deterministic keyword fallback.
"""
LLM-powered persona recommender.
 
Maps a free-text description of a visitor's role/challenges to one of the
three 'Solutions to benefit every role' personas, using structured JSON
output so the response can be parsed reliably.
"""
import json
import logging
 
from app.data.seed_data import SOLUTION_PERSONAS
from app.llm.client import LLMUnavailableError, OpenAIClient
from app.models.schemas import PersonaKey, RecommendationRequest, RecommendationResponse
 
logger = logging.getLogger(__name__)
 
_SYSTEM_PROMPT = (
    "You classify a website visitor's free-text description of their job and "
    "challenges into exactly one of these three personas: "
    "'employees' (day-to-day workplace experience, desks, rooms, visitors), "
    "'facilities' (space/asset/maintenance operations for facility or real "
    "estate teams), or 'executives' (portfolio strategy, cost, utilization "
    "analytics for leadership). "
    "Respond with ONLY a JSON object of the form "
    '{"persona": "<employees|facilities|executives>", "rationale": "<one sentence>"}. '
    "No markdown, no extra text."
)
 
 
def recommend_persona(request: RecommendationRequest, llm: OpenAIClient) -> RecommendationResponse:
    """Ask the LLM to classify the request into a persona, with a graceful fallback."""
    raw_response = llm.complete(
        _SYSTEM_PROMPT, request.role_description, temperature=0.0, max_tokens=150
    )
 
    try:
        parsed = json.loads(raw_response)
        persona_key = PersonaKey(parsed["persona"])
        rationale = str(parsed["rationale"])
    except (json.JSONDecodeError, KeyError, ValueError) as exc:
        logger.warning("Could not parse LLM recommendation response (%s); using fallback.", exc)
        persona_key = _keyword_fallback(request.role_description)
        rationale = "Recommended based on keyword matching (LLM response was unparseable)."
 
    persona = SOLUTION_PERSONAS[persona_key]
    return RecommendationResponse(
        recommended_persona=persona_key,
        rationale=rationale,
        suggested_capabilities=persona.capabilities,
    )
 
 
def _keyword_fallback(text: str) -> PersonaKey:
    """Simple deterministic fallback if the LLM is unavailable or returns bad JSON."""
    lowered = text.lower()
    if any(word in lowered for word in ("portfolio", "cost", "executive", "strategy", "cfo")):
        return PersonaKey.executives
    if any(word in lowered for word in ("maintenance", "asset", "space", "facility", "operations")):
        return PersonaKey.facilities
    return PersonaKey.employees
 
 
def recommend_persona_safe(request: RecommendationRequest, llm: OpenAIClient) -> RecommendationResponse:
    """Wrapper that falls back to keyword matching if the LLM call itself fails."""
    try:
        return recommend_persona(request, llm)
    except LLMUnavailableError:
        persona_key = _keyword_fallback(request.role_description)
        persona = SOLUTION_PERSONAS[persona_key]
        return RecommendationResponse(
            recommended_persona=persona_key,
            rationale="Recommended based on keyword matching (LLM temporarily unavailable).",
            suggested_capabilities=persona.capabilities,
        )
 
