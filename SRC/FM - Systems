    """Look up a featured resource by exact title."""
    return next((r for r in FEATURED_RESOURCES if r.title == title), None)
 
 
def generate_ai_teaser(resource: Resource, llm: OpenAIClient) -> ResourceSummaryResponse:
    """Use the LLM to produce a short, punchy teaser line for a resource."""
    user_prompt = (
        f"Resource type: {resource.resource_type.value}\n"
        f"Title: {resource.title}\n"
        f"Description: {resource.description}"
    )
    teaser = llm.complete(_TEASER_SYSTEM_PROMPT, user_prompt, temperature=0.7, max_tokens=60)
    return ResourceSummaryResponse(title=resource.title, ai_teaser=teaser)
 
