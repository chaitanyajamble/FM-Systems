# --------------------------------------------------------------------------
# HELPERS
# --------------------------------------------------------------------------
def load_page(driver, wait_selector=("tag name", "body"), timeout=15):
    start = time.time()
    driver.get(URL)
    WebDriverWait(driver, timeout).until(
        EC.presence_of_element_located(
            (By.TAG_NAME, wait_selector[1]) if wait_selector[0] == "tag name"
            else wait_selector
        )
    )
    return time.time() - start


def get_console_errors(driver):
    """Only supported on Chromium-based browsers (Chrome/Edge)."""
    try:
        logs = driver.get_log("browser")
        return [l for l in logs if l.get("level") == "SEVERE"]
    except Exception:
        return [] # Firefox doesn't support this log type via Selenium


def save_screenshot(driver, name):
    path = os.path.join(SCREENSHOT_DIR, f"{name}.png")
    driver.save_screenshot(path)
    return path


