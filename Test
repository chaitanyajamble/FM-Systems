class TestPageLoad:
    def test_page_loads_successfully(self, driver):
        load_time = load_page(driver)
        assert driver.title, "Page title is empty"
        assert load_time < 10, f"Page took too long to load: {load_time:.2f}s"
        print(f"[{driver.browser_name}] Loaded in {load_time:.2f}s | Title: {driver.title!r}")

    def test_http_status_ok(self):
        resp = requests.get(URL, timeout=15, allow_redirects=True)
        assert resp.status_code == 200, f"Page returned status {resp.status_code}"

    def test_no_severe_console_errors(self, driver):
        load_page(driver)
        errors = get_console_errors(driver)
        assert not errors, f"[{driver.browser_name}] Console errors found: {errors}"


class TestCoreUIElements:
    def test_header_and_nav_present(self, driver):
        load_page(driver)
        header = driver.find_elements(By.CSS_SELECTOR, "header, [role='banner'], nav")
        assert header, f"[{driver.browser_name}] No header/nav element found"
        assert any(el.is_displayed() for el in header), "Header/nav not visible"

    def test_footer_present(self, driver):
        load_page(driver)
        footer = driver.find_elements(By.CSS_SELECTOR, "footer, [role='contentinfo']")
        assert footer, f"[{driver.browser_name}] No footer element found"

    def test_main_heading_present(self, driver):
        load_page(driver)
        headings = driver.find_elements(By.CSS_SELECTOR, "h1, h2")
        visible_headings = [h.text.strip() for h in headings if h.is_displayed() and h.text.strip()]
        assert visible_headings, f"[{driver.browser_name}] No visible heading text found"
        print(f"[{driver.browser_name}] First heading: {visible_headings[0]!r}")

    def test_cta_buttons_or_links_present(self, driver):
        load_page(driver)
        ctas = driver.find_elements(
            By.CSS_SELECTOR, "a.button, a.btn, button, [class*='cta']"
        )
        assert ctas, f"[{driver.browser_name}] No CTA buttons/links found on page"


class TestNavigationAndLinks:
    def test_nav_links_are_clickable(self, driver):
        load_page(driver)
        nav_links = driver.find_elements(By.CSS_SELECTOR, "nav a[href]")
        assert nav_links, f"[{driver.browser_name}] No nav links found"
        broken = []
        for link in nav_links[:8]: # cap to keep runtime reasonable
            href = link.get_attribute("href")
            if not href or href.startswith("mailto:") or href.startswith("tel:"):
                continue
            try:
                r = requests.head(href, timeout=10, allow_redirects=True)
                if r.status_code >= 400:
                    broken.append((href, r.status_code))
            except requests.RequestException as exc:
                broken.append((href, str(exc)))
        assert not broken, f"[{driver.browser_name}] Broken nav links: {broken}"

    def test_all_page_links_status(self, driver):
        load_page(driver)
        links = driver.find_elements(By.CSS_SELECTOR, "a[href]")
        hrefs = {
            l.get_attribute("href")
            for l in links
            if l.get_attribute("href")
            and l.get_attribute("href").startswith("http")
        }
        broken = []
        for href in list(hrefs)[:25]: # cap for runtime
            try:
                r = requests.head(href, timeout=10, allow_redirects=True)
                if r.status_code >= 400:
                    # retry with GET in case server disallows HEAD
                    r = requests.get(href, timeout=10, allow_redirects=True)
                if r.status_code >= 400:
                    broken.append((href, r.status_code))
            except requests.RequestException as exc:
                broken.append((href, str(exc)))
        assert not broken, f"[{driver.browser_name}] Broken links found: {broken}"


class TestResponsiveDesign:
    @pytest.mark.parametrize("viewport_name", VIEWPORTS.keys())
    def test_no_horizontal_overflow(self, driver, viewport_name):
        width, height = VIEWPORTS[viewport_name]
        driver.set_window_size(width, height)
        load_page(driver)
        scroll_width = driver.execute_script("return document.documentElement.scrollWidth")
        client_width = driver.execute_script("return document.documentElement.clientWidth")
        save_screenshot(driver, f"{driver.browser_name}_{viewport_name}")
        assert scroll_width <= client_width + 5, (
            f"[{driver.browser_name}/{viewport_name}] Horizontal overflow: "
            f"scrollWidth={scroll_width} > clientWidth={client_width}"
        )

    @pytest.mark.parametrize("viewport_name", ["mobile"])
    def test_mobile_nav_accessible(self, driver, viewport_name):
        width, height = VIEWPORTS[viewport_name]
        driver.set_window_size(width, height)
        load_page(driver)
        # Look for a common hamburger/menu toggle pattern
        toggles = driver.find_elements(
            By.CSS_SELECTOR,
            "[class*='menu-toggle'], [class*='hamburger'], [aria-label*='menu' i], button[class*='nav']",
        )
        nav = driver.find_elements(By.CSS_SELECTOR, "nav")
        assert toggles or nav, f"[{driver.browser_name}] No mobile nav or toggle found"


class TestVisualRegressionCapture:
    def test_capture_full_page_screenshot(self, driver):
        load_page(driver)
        path = save_screenshot(driver, f"{driver.browser_name}_full_page")
        assert os.path.exists(path)
        print(f"[{driver.browser_name}] Screenshot saved: {path}")
